diff --git a/loongarch64_adaptation/smoke_bzlmod/src/lib.rs b/loongarch64_adaptation/smoke_bzlmod/src/lib.rs
new file mode 100644
index 000000000..606a6393f
--- /dev/null
+++ b/loongarch64_adaptation/smoke_bzlmod/src/lib.rs
@@ -0,0 +1,12 @@
+pub fn render(value: u64) -> String {
+    let mut buffer = itoa::Buffer::new();
+    format!("{}:{}", env!("FROM_BUILD_SCRIPT"), buffer.format(value))
+}
+
+#[cfg(test)]
+mod tests {
+    #[test]
+    fn render_uses_build_script_env_and_third_party_crate() {
+        assert_eq!("loongarch64-smoke:42", crate::render(42));
+    }
+}
