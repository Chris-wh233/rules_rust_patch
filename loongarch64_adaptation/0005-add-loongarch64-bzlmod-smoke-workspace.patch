diff --git a/loongarch64_adaptation/smoke_bzlmod/MODULE.bazel b/loongarch64_adaptation/smoke_bzlmod/MODULE.bazel
new file mode 100644
index 000000000..9c525a9e5
--- /dev/null
+++ b/loongarch64_adaptation/smoke_bzlmod/MODULE.bazel
@@ -0,0 +1,35 @@
+module(
+    name = "rules_rust_loongarch64_smoke",
+    version = "0.0.0",
+)
+
+bazel_dep(
+    name = "rules_rust",
+    version = "0.42.1",
+)
+
+# This smoke workspace is intended to be run from
+# rules_rust/loongarch64_adaptation/smoke_bzlmod, so ../.. points at the
+# patched rules_rust checkout under validation.
+local_path_override(
+    module_name = "rules_rust",
+    path = "../..",
+)
+
+rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
+rust.toolchain(edition = "2021")
+use_repo(rust, "rust_toolchains")
+
+register_toolchains("@rust_toolchains//:all")
+
+crate = use_extension("@rules_rust//crate_universe:extension.bzl", "crate")
+crate.spec(
+    package = "itoa",
+    version = "1.0.10",
+)
+crate.from_specs(
+    supported_platform_triples = [
+        "loongarch64-unknown-linux-gnu",
+    ],
+)
+use_repo(crate, "crates")
diff --git a/loongarch64_adaptation/smoke_bzlmod/BUILD.bazel b/loongarch64_adaptation/smoke_bzlmod/BUILD.bazel
new file mode 100644
index 000000000..e9fa5aa56
--- /dev/null
+++ b/loongarch64_adaptation/smoke_bzlmod/BUILD.bazel
@@ -0,0 +1,31 @@
+load("@rules_rust//cargo:defs.bzl", "cargo_build_script")
+load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")
+
+cargo_build_script(
+    name = "build_script",
+    srcs = ["build.rs"],
+    edition = "2021",
+)
+
+rust_library(
+    name = "smoke_lib",
+    srcs = ["src/lib.rs"],
+    edition = "2021",
+    deps = [
+        ":build_script",
+        "@crates//:itoa",
+    ],
+)
+
+rust_binary(
+    name = "smoke_bin",
+    srcs = ["src/main.rs"],
+    edition = "2021",
+    deps = [":smoke_lib"],
+)
+
+rust_test(
+    name = "smoke_test",
+    crate = ":smoke_lib",
+    edition = "2021",
+)
