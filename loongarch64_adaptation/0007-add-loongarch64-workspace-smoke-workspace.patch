+# LoongArch64 WORKSPACE Smoke Workspace
+
+Run this workspace from inside a patched `rules_rust` checkout:
+
+```bash
+cd loongarch64_adaptation/smoke_workspace
+CARGO_BAZEL_REPIN=1 CARGO_BAZEL_REPIN_ONLY=crates bazel sync --only=crates
+bazel sync
+bazel test //:smoke_test
+bazel run //:smoke_bin
+```
+
+The first command is expected to populate `Cargo.Bazel.lock` and `cargo-bazel-lock.json`. They are committed as placeholder files because `crates_repository` requires the lockfile paths to exist before the first repin.
+
+Expected `bazel run` output:
+
+```text
+loongarch64-workspace-smoke:64
+```
+
+This validates:
+- WORKSPACE-mode `rules_rust_dependencies()`;
+- WORKSPACE-mode `rust_register_toolchains()` on a LoongArch64 host;
+- `crate_universe_dependencies(bootstrap = True)` building `cargo-bazel` on LoongArch64;
+- `crates_repository` with `supported_platform_triples = ["loongarch64-unknown-linux-gnu"]`;
+- `rust_library`, `rust_test`, `rust_binary`, and `cargo_build_script`.
+
+If toolchain resolution fails, rerun the test with:
+
+```bash
+bazel test //:smoke_test --toolchain_resolution_debug='@rules_rust//rust:toolchain_type'
+```
diff --git a/loongarch64_adaptation/smoke_workspace/WORKSPACE.bazel b/loongarch64_adaptation/smoke_workspace/WORKSPACE.bazel
new file mode 100644
index 00000000..9065fe64
--- /dev/null
+++ b/loongarch64_adaptation/smoke_workspace/WORKSPACE.bazel
@@ -0,0 +1,42 @@
+workspace(name = "rules_rust_loongarch64_workspace_smoke")
+
+# This smoke workspace is intended to be run from
+# rules_rust/loongarch64_adaptation/smoke_workspace, so ../.. points at the
+# patched rules_rust checkout under validation.
+local_repository(
+    name = "rules_rust",
+    path = "../..",
+)
+
+load("@rules_rust//rust:repositories.bzl", "rules_rust_dependencies", "rust_register_toolchains")
+
+rules_rust_dependencies()
+
+rust_register_toolchains(
+    edition = "2021",
+)
+
+load("@rules_rust//crate_universe:repositories.bzl", "crate_universe_dependencies")
+
+crate_universe_dependencies(bootstrap = True)
+
+load("@rules_rust//crate_universe:defs.bzl", "crate", "crates_repository")
+
+crates_repository(
+    name = "crates",
+    cargo_lockfile = "//:Cargo.Bazel.lock",
+    generator = "@cargo_bazel_bootstrap//:cargo-bazel",
+    lockfile = "//:cargo-bazel-lock.json",
+    packages = {
+        "itoa": crate.spec(
+            version = "1.0.10",
+        ),
+    },
+    supported_platform_triples = [
+        "loongarch64-unknown-linux-gnu",
+    ],
+)
+
+load("@crates//:defs.bzl", "crate_repositories")
+
+crate_repositories()
